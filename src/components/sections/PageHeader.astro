---
import type { Brand } from "../../../types/types";
import { getTranslations } from "../../utils/i18n";

const { lang } = Astro.params;
const t = await getTranslations(lang as keyof typeof import("../../utils/i18n").languages);

const { name = t.nav.allProducts, description, brands, categories } = Astro.props;

// Get current URL parameters for filter synchronization
const currentBrand = Astro.url.searchParams.get("brandId") || "";
const currentCategory = Astro.url.searchParams.get("categoryId") || "";
// const currentPage = Astro.url.searchParams.get("page") || "1";
---

<div class="relative animate-fadeInUp w-full flex justify-center items-center my-6">
	<button
		id="filters-button"
		type="button"
		class="absolute cursor-pointer left-0 top-1/2 transform -translate-y-1/2 group flex items-center justify-center w-8 h-8 md:w-12 md:h-12 bg-gradient-primary hover:bg-gradient-secondary rounded-full shadow-vibrant hover:shadow-vibrant-lg hover:scale-110 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-opacity-50"
		aria-label="Toggle filters"
	>
		<span
			id="filter-icon"
			class="icon-[mdi--sort] text-white dark:text-text text-xl md:text-2xl transition-transform duration-300"
		></span>
	</button>

	<div class="flex flex-col gap-10 justify-center items-center">
		<div class="flex flex-col justify-center items-center gap-10">
			<h1
				class="text-2xl p-3 md:p-8 md:text-5xl lg:text-6xl font-bold text-center relative animate-glow rounded-2xl text-white"
			>
				{name}
			</h1>
		</div>
	</div>

	<a
		href="/"
		class="absolute cursor-pointer right-0 top-1/2 transform -translate-y-1/2 group flex items-center justify-center w-8 h-8 md:w-12 md:h-12 bg-gradient-primary hover:bg-gradient-secondary rounded-full shadow-vibrant hover:shadow-vibrant-lg hover:scale-110 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-opacity-50"
	>
		<span class="icon-[maki--arrow] text-white dark:text-text text-xl md:text-2xl"></span>
	</a>
</div>
{description && <p class="text-xl text-center mb-6">{description}</p>}

<div
	id="filters-container"
	class="filters-container hidden overflow-hidden transition-all duration-500 ease-in-out transform opacity-0 max-h-0 pt-5"
>
	<div
		class="flex flex-col sm:flex-row gap-4 pt-6 pb-4 px-4 bg-gradient-to-r from-primary/5 to-secondary/5 rounded-lg border border-primary/20 backdrop-blur-sm"
	>
		<div class="flex flex-col gap-2 flex-1">
			<label for="brand-filter" class="text-sm font-medium text-text-secondary">
				{t.filters?.brand || "Brand"}
			</label>
			<select
				id="brand-filter"
				class="w-full px-3 py-2 bg-background border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all duration-200 hover:border-primary/50"
			>
				<option value="">{t.filters?.allBrands || "All Brands"}</option>
				{
					brands?.map((brand: Brand) => (
						<option value={brand.id} selected={currentBrand === brand.name}>
							{brand.name}
						</option>
					))
				}
			</select>
		</div>

		<div class="flex flex-col gap-2 flex-1">
			<label for="category-filter" class="text-sm font-medium text-text-secondary">
				{t.filters?.category || "Category"}
			</label>
			<select
				id="category-filter"
				class="w-full px-3 py-2 bg-background border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-all duration-200 hover:border-primary/50"
			>
				<option value="">{t.filters?.allCategories || "All Categories"}</option>
				{
					categories?.map((category: Brand) => (
						<option value={category.id} selected={currentCategory === category.name}>
							{category.name}
						</option>
					))
				}
			</select>
		</div>

		<div class="flex items-end">
			<button
				id="clear-filters"
				type="button"
				class="px-4 py-2 text-sm font-medium text-text-secondary hover:text-primary border border-gray-300 dark:border-gray-600 rounded-md hover:border-primary/50 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary/50"
			>
				{t.filters?.clear || "Clear"}
			</button>
		</div>
	</div>
</div>

<script>
	// Enhanced PageHeader functionality with filter toggle and URL synchronization
	class PageHeaderController {
		filtersContainer: HTMLElement | null;
		filtersButton: HTMLElement | null;
		filterIcon: HTMLElement | null;
		brandFilter: HTMLSelectElement | null;
		categoryFilter: HTMLSelectElement | null;
		clearButton: HTMLElement | null;
		isFiltersVisible: boolean;

		constructor() {
			this.filtersContainer = document.getElementById("filters-container");
			this.filtersButton = document.getElementById("filters-button");
			this.filterIcon = document.getElementById("filter-icon");
			this.brandFilter = document.getElementById("brand-filter") as HTMLSelectElement;
			this.categoryFilter = document.getElementById("category-filter") as HTMLSelectElement;
			this.clearButton = document.getElementById("clear-filters");
			this.isFiltersVisible = false;

			this.init();
		}

		init() {
			try {
				this.setupEventListeners();
				this.syncFiltersWithURL();
				this.checkInitialFilterState();
			} catch (error) {
				console.error("Error initializing PageHeader:", error);
			}
		}

		setupEventListeners() {
			// Toggle filters visibility
			if (this.filtersButton) {
				this.filtersButton.addEventListener("click", (e) => {
					e.preventDefault();
					this.toggleFilters();
				});
			}

			// Filter change handlers
			if (this.brandFilter) {
				this.brandFilter.addEventListener("change", () => {
					this.updateURL();
				});
			}

			if (this.categoryFilter) {
				this.categoryFilter.addEventListener("change", () => {
					this.updateURL();
				});
			}

			// Clear filters
			if (this.clearButton) {
				this.clearButton.addEventListener("click", () => {
					this.clearFilters();
				});
			}

			// Handle browser back/forward
			window.addEventListener("popstate", () => {
				this.syncFiltersWithURL();
			});

			// Handle responsive behavior
			window.addEventListener("resize", () => {
				this.handleResize();
			});
		}

		toggleFilters() {
			if (!this.filtersContainer) return;

			this.isFiltersVisible = !this.isFiltersVisible;

			if (this.isFiltersVisible) {
				this.showFilters();
			} else {
				this.hideFilters();
			}
		}

		showFilters() {
			if (!this.filtersContainer) return;

			// Remove hidden class and prepare for animation
			this.filtersContainer.classList.remove("hidden");

			// Force reflow
			this.filtersContainer.offsetHeight;

			// Add visible classes with animation
			this.filtersContainer.classList.remove("opacity-0", "max-h-0");
			this.filtersContainer.classList.add("opacity-100", "max-h-96");

			// Rotate filter icon
			if (this.filterIcon) {
				this.filterIcon.style.transform = "rotate(180deg)";
			}

			// Update ARIA attributes for accessibility
			if (this.filtersButton) {
				this.filtersButton.setAttribute("aria-expanded", "true");
			}
		}

		hideFilters() {
			if (!this.filtersContainer) return;

			// Start hide animation
			this.filtersContainer.classList.remove("opacity-100", "max-h-96");
			this.filtersContainer.classList.add("opacity-0", "max-h-0");

			// Reset filter icon
			if (this.filterIcon) {
				this.filterIcon.style.transform = "rotate(0deg)";
			}

			// Update ARIA attributes
			if (this.filtersButton) {
				this.filtersButton.setAttribute("aria-expanded", "false");
			}

			// Hide completely after animation
			setTimeout(() => {
				if (!this.isFiltersVisible && this.filtersContainer) {
					this.filtersContainer.classList.add("hidden");
				}
			}, 500);
		}

		updateURL() {
			try {
				const url = new URL(window.location.href);
				const params = new URLSearchParams(window.location.search);

				// Get current filter values
				const brandValue = this.brandFilter?.value || "";
				const categoryValue = this.categoryFilter?.value || "";

				// Update or remove parameters
				if (brandValue) {
					params.set("brandId", brandValue);
				} else {
					params.delete("brandId");
				}

				if (categoryValue) {
					params.set("categoryId", categoryValue);
				} else {
					params.delete("categoryId");
				}

				// Reset to page 1 when filters change
				params.delete("page");

				// Update URL without page reload
				const newURL = `${url.pathname}${params.toString() ? "?" + params.toString() : ""}`;
				window.history.pushState({}, "", newURL);

				// Reload page to apply filters
				window.location.reload();
			} catch (error) {
				console.error("Error updating URL:", error);
			}
		}

		syncFiltersWithURL() {
			try {
				const params = new URLSearchParams(window.location.search);
				const brand = params.get("brandId") || "";
				const category = params.get("categoryId") || "";

				// Update filter selections
				if (this.brandFilter) {
					this.brandFilter.value = brand;
				}

				if (this.categoryFilter) {
					this.categoryFilter.value = category;
				}
			} catch (error) {
				console.error("Error syncing filters with URL:", error);
			}
		}

		clearFilters() {
			try {
				// Reset filter values
				if (this.brandFilter) this.brandFilter.value = "";
				if (this.categoryFilter) this.categoryFilter.value = "";

				// Update URL
				this.updateURL();
			} catch (error) {
				console.error("Error clearing filters:", error);
			}
		}

		checkInitialFilterState() {
			// Show filters if any are active
			const params = new URLSearchParams(window.location.search);
			const hasActiveFilters = params.has("brandId") || params.has("categoryId");

			if (hasActiveFilters && !this.isFiltersVisible) {
				this.isFiltersVisible = true;
				this.showFilters();
			}
		}

		handleResize() {
			// Ensure responsive behavior on window resize
			if (window.innerWidth < 640 && this.isFiltersVisible) {
				// Adjust layout for mobile if needed
				if (this.filtersContainer) {
					this.filtersContainer.style.maxHeight = "none";
				}
			}
		}
	}

	// Initialize when DOM is loaded
	document.addEventListener("DOMContentLoaded", () => {
		new PageHeaderController();
	});

	// Also initialize immediately if DOM is already loaded
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => {
			new PageHeaderController();
		});
	} else {
		new PageHeaderController();
	}
</script>
