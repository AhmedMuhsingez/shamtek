							{t.nav.allProducts}
						</a>
					</li>
					<li>
						<a
							href="/contact"
							class="text-gray-300 hover:text-primary transition-colors duration-300 flex items-center gap-2"
						>
							<span class="w-1 h-1 bg-primary rounded-full"></span>
							{t.nav.contact}
						</a>
					</li>
				</ul>
			</div> -->

			<!-- Contact Info -->
			<div class="animate-slideInLeft" style="animation-delay: 0.4s;">
				<h4 class="text-xl font-semibold mb-6 text-white">{t.footer.contactInfo}</h4>
				<div class="space-y-4">
					<div class="flex items-center gap-3 text-gray-300">
						<div
							class="w-8 h-8 bg-gradient-secondary rounded-lg flex items-center justify-center"
						>
							<span class="text-2xl icon-[ic--outline-email]"></span>
						</div>
						<span>{companyData.email}</span>
					</div>
					<div class="flex items-center gap-3 text-gray-300">
						<div
							class="w-8 h-8 bg-gradient-accent rounded-lg flex items-center justify-center"
						>
							<span class="text-2xl icon-[mdi-light--phone]"></span>
						</div>
						<span>{companyData.phone}</span>
					</div>
					<div class="flex gap-3 text-gray-300 content-center items-center">
						<div
							class="w-8 h-8 bg-gradient-primary rounded-lg flex items-center justify-center mt-1"
						>
							<span class="text-2xl icon-[line-md--my-location]"></span>
						</div>
						<span class="leading-relaxed"> Aleppo, Syria </span>
					</div>
				</div>
			</div>
		</div>

		<!-- Bottom Bar -->
		<div
			class="border-t border-gray-700/50 pt-8 animate-fadeInUp"
			style="animation-delay: 0.6s;"
		>
			<div class="flex flex-col md:flex-row justify-between items-center gap-4">
				<p class="text-gray-500 text-center md:text-left">
					&copy; {t.footer.allRightsReserved}. {t.footer.poweredBy}
					<a
						href="https://www.muhsingez.com/"
						class="hover:text-primary transition-colors">Ahmed Muhsingez</a
					>
				</p>

				<p class="text-gray-500 text-center md:text-left">
					2025 {t.footer.companyName}
				</p>

				<div class="flex items-center gap-2 text-sm text-gray-400">
					<a href="#" class="hover:text-primary transition-colors">{t.footer.privacy}</a
					>
					<span>•</span>
					<a href="#" class="hover:text-primary transition-colors">{t.footer.terms}</a>
					<span>•</span>
					<a href="#" class="hover:text-primary transition-colors">{t.footer.cookies}</a
					>
				</div>
			</div>
		</div>
	</div>
</footer>
