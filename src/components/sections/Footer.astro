---
import socialButtons from "../../data/social-buttons.json";
import { IconBrandFacebook, IconBrandInstagram, IconUserCircle } from "@tabler/icons-react";
import { getLangFromUrl, getTranslations } from "../../utils/i18n.ts";

const lang = getLangFromUrl(Astro.url);
const t = await getTranslations(lang);

interface Props {
	currentLang?: string;
}

const { currentLang = 'ar' } = Astro.props;

const iconMap = {
	instagram: IconBrandInstagram,
	facebook: IconBrandFacebook,
	personal: IconUserCircle,
};
---

<footer class="relative bg-gradient-to-br from-gray-900 via-gray-800 to-black text-white py-16 overflow-hidden">
	<!-- Background decorations -->
	<div class="absolute top-0 left-0 w-full h-full opacity-10">
		<div class="absolute top-10 left-10 w-32 h-32 bg-gradient-primary rounded-full animate-float"></div>
		<div class="absolute bottom-20 right-20 w-24 h-24 bg-gradient-secondary rounded-full animate-float" style="animation-delay: 1s;"></div>
		<div class="absolute top-1/2 left-1/3 w-16 h-16 bg-gradient-accent rounded-full animate-float" style="animation-delay: 2s;"></div>
	</div>

	<div class="relative z-10 container mx-auto px-4">
		<!-- Main Footer Content -->
		<div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
			<!-- Company Info -->
			<div class="md:col-span-2 animate-fadeInUp">
				<div class="flex items-center gap-3 mb-4">
					<div class="w-12 h-12 bg-gradient-primary rounded-xl flex items-center justify-center">
						<span class="text-2xl font-bold">ش</span>
					</div>
					<h3 class="text-2xl font-bold bg-gradient-primary bg-clip-text text-transparent">
						{t.footer.companyName}
					</h3>
				</div>
				<p class="text-gray-300 text-lg mb-6 leading-relaxed">
					{t.footer.description}
				</p>
				<div class="flex flex-wrap gap-4">
					{socialButtons.map((button, index) => (
						<a
							href={button.url}
							target="_blank"
							rel="noopener noreferrer"
							class="group w-12 h-12 bg-white/10 hover:bg-gradient-primary rounded-xl flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:shadow-vibrant animate-slideInRight"
							style={`animation-delay: ${index * 0.1}s;`}
							aria-label={button.name}
						>
							<i class={`${button.icon} text-xl group-hover:text-white transition-colors`}></i>
						</a>
					))}
				</div>
			</div>

			<!-- Quick Links -->
			<div class="animate-slideInRight" style="animation-delay: 0.2s;">
				<h4 class="text-xl font-semibold mb-6 text-white">{t.footer.quickLinks}</h4>
				<ul class="space-y-3">
					<li>
						<a href="/" class="text-gray-300 hover:text-primary transition-colors duration-300 flex items-center gap-2">
							<span class="w-1 h-1 bg-primary rounded-full"></span>
							{t.nav.home}
						</a>
					</li>
					<li>
						<a href="/about" class="text-gray-300 hover:text-primary transition-colors duration-300 flex items-center gap-2">
							<span class="w-1 h-1 bg-primary rounded-full"></span>
							{t.nav.about}
						</a>
					</li>
					<li>
						<a href="/all-products" class="text-gray-300 hover:text-primary transition-colors duration-300 flex items-center gap-2">
							<span class="w-1 h-1 bg-primary rounded-full"></span>
							{t.nav.allProducts}
						</a>
					</li>
					<li>
						<a href="/contact" class="text-gray-300 hover:text-primary transition-colors duration-300 flex items-center gap-2">
							<span class="w-1 h-1 bg-primary rounded-full"></span>
							{t.nav.contact}
						</a>
					</li>
				</ul>
			</div>

			<!-- Contact Info -->
			<div class="animate-slideInLeft" style="animation-delay: 0.4s;">
				<h4 class="text-xl font-semibold mb-6 text-white">{t.footer.contactInfo}</h4>
				<div class="space-y-4">
					<div class="flex items-center gap-3 text-gray-300">
						<div class="w-8 h-8 bg-gradient-secondary rounded-lg flex items-center justify-center">
							<i class="fas fa-envelope text-sm"></i>
						</div>
						<span>info@shamtek.com</span>
					</div>
					<div class="flex items-center gap-3 text-gray-300">
						<div class="w-8 h-8 bg-gradient-accent rounded-lg flex items-center justify-center">
							<i class="fas fa-phone text-sm"></i>
						</div>
						<span>+90 XXX XXX XXXX</span>
					</div>
					<div class="flex items-start gap-3 text-gray-300">
						<div class="w-8 h-8 bg-gradient-primary rounded-lg flex items-center justify-center mt-1">
							<i class="fas fa-map-marker-alt text-sm"></i>
						</div>
						<span class="leading-relaxed">
							{t.common.location}
						</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Bottom Bar -->
		<div class="border-t border-gray-700/50 pt-8 animate-fadeInUp" style="animation-delay: 0.6s;">
			<div class="flex flex-col md:flex-row justify-between items-center gap-4">
				<p class="text-gray-400 text-center md:text-left">
					&copy; 2024 {t.footer.companyName}. {t.footer.allRightsReserved}
				</p>
				<div class="flex items-center gap-6 text-sm text-gray-400">
					<a href="#" class="hover:text-primary transition-colors">{t.footer.privacy}</a>
					<span>•</span>
					<a href="#" class="hover:text-primary transition-colors">{t.footer.terms}</a>
					<span>•</span>
					<a href="#" class="hover:text-primary transition-colors">{t.footer.cookies}</a>
				</div>
			</div>
		</div>
	</div>
</footer>
