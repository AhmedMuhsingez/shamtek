---
import { getLangFromUrl, getTranslations } from "../../utils/i18n.ts";
import { companyData } from "../../data/company-details";
import { socialButtons } from "../../data/social-buttons";

const lang = getLangFromUrl(Astro.url);
const t = await getTranslations(lang);

interface Props {
	currentLang?: string;
}

const { currentLang = "ar" } = Astro.props;
---

<footer
	class="relative bg-gradient-to-br from-gray-900 via-gray-800 to-black text-white py-16 overflow-hidden"
>
	<!-- Background decorations -->
	<div class="absolute top-0 left-0 w-full h-full opacity-10">
		<div
			class="absolute top-10 left-10 w-32 h-32 bg-gradient-primary rounded-full animate-float"
		>
		</div>
		<div
			class="absolute bottom-20 right-20 w-24 h-24 bg-gradient-secondary rounded-full animate-float"
			style="animation-delay: 1s;"
		>
		</div>
		<div
			class="absolute top-1/2 left-1/3 w-16 h-16 bg-gradient-accent rounded-full animate-float"
			style="animation-delay: 2s;"
		>
		</div>
	</div>

	<div class="relative z-10 container mx-auto px-4">
		<!-- Main Footer Content -->
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
			<!-- Company Info -->
			<div class="md:col-span-2 animate-fadeInUp">
				<div class="flex items-center gap-3 mb-4">
					<h3 class="text-2xl font-bold">
						{t.footer.companyName}
					</h3>
				</div>
				<p class="text-gray-300 text-lg mb-6 leading-relaxed">
					{t.footer.description}
				</p>
				<div class="flex flex-wrap gap-4 justify-center md:justify-start">
					{
						socialButtons.map((button, index) => (
							<a
								href={button.url}
								target="_blank"
								rel="noopener noreferrer"
								class="group w-12 h-12 bg-white/10 hover:bg-gradient-primary rounded-xl flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:shadow-vibrant animate-slideInRight"
								style={`animation-delay: ${index * 0.1}s;`}
								aria-label={button.name}
							>
								<span
									class={`${button.icon} text-xl group-hover:text-white transition-colors`}
								/>
							</a>
						))
					}
				</div>
			</div>

			<!-- Quick Links -->
			<!-- <div class="animate-slideInRight" style="animation-delay: 0.2s;">
				<h4 class="text-xl font-semibold mb-6 text-white">{t.footer.quickLinks}</h4>
				<ul class="space-y-3">
					<li>
						<a
							href="/"
							class="text-gray-300 hover:text-primary transition-colors duration-300 flex items-center gap-2"
						>
							<span class="w-1 h-1 bg-primary rounded-full"></span>
							{t.nav.home}
						</a>
					</li>
					<li>
						<a
							href="/about"
							class="text-gray-300 hover:text-primary transition-colors duration-300 flex items-center gap-2"
						>
							<span class="w-1 h-1 bg-primary rounded-full"></span>
							{t.nav.about}
						</a>
					</li>
					<li>
						<a
							href="/all-products"
							class="text-gray-300 hover:text-primary transition-colors duration-300 flex items-center gap-2"
