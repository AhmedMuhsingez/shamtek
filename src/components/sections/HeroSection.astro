---
import type { CompanyDetails } from "../../../types/types";
import { baseAPI } from "../../api/endpoints";
import { getTranslations, useTranslatedPath } from "../../utils/i18n";

const company = await fetch(`${baseAPI}/company`);
const data: CompanyDetails = await company.json();

const { lang } = Astro.params;
const t = await getTranslations(lang as keyof typeof import("../../utils/i18n").languages);
const translatePath = useTranslatedPath(
	lang as keyof typeof import("../../utils/i18n").languages
);
---

<section class="relative py-20 overflow-hidden mb-16">
	<div class="absolute inset-0 bg-gradient-primary opacity-50 dark:opacity-5 rounded-lg"></div>
	<div class="relative z-10 text-center animate-fadeInUp">
		<h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
			{t.home.welcome}
			{lang != "tr" && data.name}
		</h1>
		<p class="text-xl md:text-2xl text-white max-w-4xl mx-auto mb-8">
			{t.home.subtitle}
		</p>

		<p class="text-xl md:text-2xl text-white max-w-4xl mx-auto mb-8">
			{data.address}
		</p>
		<p class="text-xl md:text-2xl text-white max-w-4xl mx-auto mb-8">
			{data.phone}
		</p>

		<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
			<a
				href={translatePath("/all-products")}
				class="bg-gradient-primary text-white px-8 py-4 rounded-lg font-semibold text-lg shadow-vibrant-md hover:shadow-vibrant-lg transform hover:scale-105 transition-all duration-300 animate-pulse-custom"
			>
				{t.nav.allProducts}
			</a>
			<a
				href={translatePath("/contact")}
				class="glass px-8 py-4 !rounded-lg font-semibold text-lg text-text hover:text-primary transition-all duration-300 transform hover:scale-105"
			>
				{t.nav.contact}
			</a>
		</div>
	</div>
	<div
		class="absolute top-20 left-10 w-32 h-32 bg-gradient-secondary rounded-full opacity-20 animate-float"
	>
	</div>
	<div
		class="absolute bottom-20 right-10 w-24 h-24 bg-gradient-accent rounded-full opacity-20 animate-float"
		style="animation-delay: 1s;"
	>
	</div>
</section>
