---
import type { CompanyDetails } from "../../../types/types";
import { baseAPI } from "../../api/endpoints";

const company = await fetch(`${baseAPI}/company`);
const data: CompanyDetails = await company.json();
---

<div
	class="flex flex-col-reverse md:flex-row items-center gap-4 px-3 py-6 lg:px-20 lg:py-6 border-black text-white bg-white/90 shadow-xl shadow-[#ece6ff] dark:shadow-black dark:shadow-2xl dark:bg-background-onBg rounded-2xl"
>
	<div class="flex flex-col justify-center text-center w-full gap-y-4 md:gap-y-10">
		<span class="text-3xl md:text-5xl font-bold text-black/80 dark:text-white">
			{data.name}
		</span>

		<span class="text-2xl md:text-3xl text-black/80 dark:text-white">
			{data.description}
		</span>

		<span class="text-2xl md:text-3xl text-black/80 dark:text-white">
			{data.address}
		</span>

		<span class="text-2xl md:text-3xl text-black/80 dark:text-white">
			{data.phone}
		</span>
	</div>

	<div class="flex justify-center md:justify-end w-full">
		<img src={data.logo as string} alt={data.name} class="w-[200px] md:w-[320px]" />
	</div>
</div>
