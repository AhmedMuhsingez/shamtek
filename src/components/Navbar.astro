---
import logo from "../assets/logo.jpeg";
import NavbarItems from "./NavbarItems.astro";
import WhatsAppButton from "./WhatsAppButton.astro";
---

<div
	class="md:px-0 sticky top-0 left-0 right-0 w-full z-40"
	style={{
		justifySelf: "anchor-center",
	}}
	id="navbar"
>
	<header
		class="w-full bg-black/5 dark:bg-black/70 backdrop-blur-lg shadow-light-card dark:shadow-dark-card flex justify-center"
	>
		<div
			id="container"
			class="w-full max-w-7xl px-6 py-4 lg:px-0 lg:py-2 flex justify-between items-center"
		>
			<div class="flex gap-2 md:gap-4 items-center">
				<a class="content-center" href={"/"}
					><img src={logo.src} class="w-12 h-12 md:w-16 md:h-16" /></a
				>
				<a class="text-2xl md:text-3xl text-text font-[600]" href={"/"}>
					<span>شام </span>
					<span class="font-light">تِك</span></a
				>
			</div>
			<NavbarItems />
			<WhatsAppButton />
		</div>
	</header>
</div>

<script></script>
