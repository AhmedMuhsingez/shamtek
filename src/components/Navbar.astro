---
import logo from "../assets/logo.jpeg";
import NavbarItems from "./NavbarItems.astro";
import WhatsAppButton from "./WhatsAppButton.astro";

import { getTranslations, useTranslatedPath } from "../utils/i18n";
import ToggleTheme from "./ToggleTheme.astro";
import NavbarProducts from "./custom/NavbarProducts";
import { companyData } from "../data/company-details";
import { categories as data } from "../data/dummy-data";

interface Props {
	currentLang?: string;
}

const { currentLang = "ar" } = Astro.props;
const t = await getTranslations(currentLang as keyof typeof import("../utils/i18n").languages);
const translatePath = useTranslatedPath(
	currentLang as keyof typeof import("../utils/i18n").languages
);
---

<div
	class="md:px-0 sticky top-0 left-0 right-0 w-full z-40"
	style={{
		justifySelf: "anchor-center",
	}}
	id="navbar"
>
	<header
		class="w-full bg-white/40 dark:bg-black/40 backdrop-blur-lg shadow-light-card dark:shadow-dark-card flex justify-center"
	>
		<div
			id="container"
			class="w-full max-w-7xl p-3 lg:px-0 lg:py-2 flex justify-between items-center"
		>
			<div class="flex gap-2 md:gap-4 items-center">
				<a
					class="content-center transition-transform duration-200 hover:scale-105"
					href={translatePath("/")}
					><img
						src={logo.src}
						class="w-12 h-12 md:w-16 md:h-16 rounded-lg shadow-sm object-cover"
						alt={`${companyData.name} logo`}
					/></a
				>
				<a
					class="text-2xl md:text-3xl text-text font-[600] hover:text-primary transition-colors duration-200"
					href={translatePath("/")}
				>
					{t.common.brandName}
				</a>
			</div>

			<NavbarItems currentLang={currentLang} />

			<div class="flex items-center gap-2">
				<div class="hidden md:block">
					<WhatsAppButton currentLang={currentLang} />
				</div>

				<div class="flex gap-3 md:hidden">
					<ToggleTheme />
					<NavbarProducts client:load categories={data} />
				</div>
			</div>
		</div>
	</header>

	<script>
		document.addEventListener("DOMContentLoaded", function () {
			const mobileThemeToggle = document.getElementById("mobile-theme-toggle");
			if (mobileThemeToggle) {
				mobileThemeToggle.addEventListener("click", function () {
					const mainThemeToggle = document.querySelector(
						"[data-theme-toggle]"
					) as HTMLElement;
					if (mainThemeToggle && "click" in mainThemeToggle) {
						(mainThemeToggle as any).click();
					} else {
						const html = document.documentElement;
						const isDark = html.classList.contains("dark");
						if (isDark) {
							html.classList.remove("dark");
							localStorage.setItem("theme", "light");
						} else {
							html.classList.add("dark");
							localStorage.setItem("theme", "dark");
						}
					}
				});
			}
		});
	</script>
</div>
