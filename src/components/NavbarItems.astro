---
import ChangeLanguage from "./ChangeLanguage.tsx";
import ToggleTheme from "./ToggleTheme.astro";
import navbar from "../data/navbar.json";
import NavbarProducts from "../components/custom/NavbarProducts.tsx";
import { getLangFromUrl, getTranslations, useTranslatedPath } from "../utils/i18n";

interface Props {
	currentLang?: string;
}

const { currentLang } = Astro.props;
const lang = currentLang || getLangFromUrl(Astro.url);
const t = await getTranslations(lang as keyof typeof import('../utils/i18n').languages);
const translatePath = useTranslatedPath(lang as keyof typeof import('../utils/i18n').languages);

const categories = await fetch(`${import.meta.env.BASE_API}/categories`);
const data = await categories.json();
---

<div
	class="hidden md:flex rounded-3xl py-2 px-4 gap-10 text-black dark:text-white bg-black/10 dark:bg-white/10 place-items-center backdrop-blur-xl"
>
	<ToggleTheme />
	<NavbarProducts client:load categories={data} />

	{
		navbar.map((item) => {
			return (
				<a href={translatePath(item.link)} class="text-lg flex gap-2">
					{item.nameKey === 'nav.about' ? t.nav.about : item.nameKey === 'nav.contact' ? t.nav.contact : item.nameKey}
				</a>
			);
		})
	}
	<ChangeLanguage client:load />
</div>
