---
import ChangeLanguage from "./ChangeLanguage.tsx";
import ToggleTheme from "./ToggleTheme.astro";
import navbar from "../data/navbar.json";
import NavbarProducts from "../components/custom/NavbarProducts.tsx";
import { getLangFromUrl, getTranslations, useTranslatedPath } from "../utils/i18n";

interface Props {
	currentLang?: string;
}

const { currentLang } = Astro.props;
const lang = currentLang || getLangFromUrl(Astro.url);
const t = await getTranslations(lang as keyof typeof import("../utils/i18n").languages);
const translatePath = useTranslatedPath(lang as keyof typeof import("../utils/i18n").languages);

const brands = await fetch(`${import.meta.env.BASE_API}/brands`);
const data = await brands.json();

const currentPath = Astro.url.pathname;
---

<div
	class="hidden md:flex rounded-3xl py-2 px-4 gap-10 text-black dark:text-white bg-black/10 dark:bg-white/10 place-items-center backdrop-blur-xl"
>
	<ToggleTheme />
	<NavbarProducts client:load categories={data} lang={lang as "ar" | "en" | "tr"} />

	{
		navbar.map((item) => {
			const isActive = currentPath.includes(item.link) && item.link !== "/";
			return (
				<a
					href={translatePath(item.link)}
					class={`navbar-link text-lg flex gap-2 relative px-3 py-2 rounded-lg transition-all duration-300 hover:bg-primary/10 hover:text-primary hover:scale-105 ${
						isActive ? "text-primary bg-primary/10 font-semibold" : ""
					}`}
					data-smooth-scroll
				>
					{item.nameKey === "nav.about"
						? t.nav.about
						: item.nameKey === "nav.contact"
							? t.nav.contact
							: item.nameKey}
				</a>
			);
		})
	}
	<ChangeLanguage client:load />
</div>

<script>
	document.addEventListener("DOMContentLoaded", function () {
		const smoothScrollLinks = document.querySelectorAll("[data-smooth-scroll]");

		smoothScrollLinks.forEach((link) => {
			link.addEventListener("click", function (e) {
				const target = e.currentTarget as HTMLAnchorElement;
				const href = target.getAttribute("href");
				if (href && href.startsWith("#")) {
					e.preventDefault();

					const targetElement = document.querySelector(href);
					if (targetElement) {
						targetElement.scrollIntoView({
							behavior: "smooth",
							block: "start",
						});
					}
				}
			});
		});
		const navbarLinks = document.querySelectorAll(".navbar-link");

		navbarLinks.forEach((link) => {
			const htmlLink = link as HTMLElement;

			htmlLink.addEventListener("mouseenter", function () {
				htmlLink.style.transform = "translateY(-2px)";
				htmlLink.style.boxShadow = "0 4px 12px rgba(102, 126, 234, 0.2)";
			});

			htmlLink.addEventListener("mouseleave", function () {
				htmlLink.style.transform = "translateY(0)";
				htmlLink.style.boxShadow = "none";
			});
		});

		function updateActiveStates() {
			const currentPath = window.location.pathname;
			const navLinks = document.querySelectorAll(".navbar-link");

			navLinks.forEach((link) => {
				const htmlLink = link as HTMLAnchorElement;
				const href = htmlLink.getAttribute("href");
				const isActive = href && currentPath.includes(href) && href !== "/";

				if (isActive) {
					htmlLink.classList.add("text-primary", "bg-primary/10", "font-semibold");
				} else {
					htmlLink.classList.remove("text-primary", "bg-primary/10", "font-semibold");
				}
			});
		}
		updateActiveStates();
		window.addEventListener("popstate", updateActiveStates);
	});
</script>
