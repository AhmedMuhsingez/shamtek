---
import type { Product } from "../../types/types";
import { cn } from "../utils/utils";
import { getLangFromUrl, useTranslations } from "../utils/i18n";

const { product } = Astro.props;
const data: Product = product;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const brandLabel = await t("products.brand");
const stockLabel = await t("products.stock");
const categoryLabel = await t("products.category");
const codeNameLabel = await t("products.codeName");

const stockState = data.stock_state?.toLowerCase();

const inStock = stockState === "in_stock";
const outOfStock = stockState === "out_of_stock";

function getStockTranslation(stockState: string) {
	const lowerStock = stockState.toLowerCase();
	if (lowerStock === "in_stock") {
		return t("products.inStock");
	} else if (lowerStock === "coming_soon") {
		return t("products.coming_soon");
	} else {
		return t("products.outOfStock");
	}
}

const stockTranslation = await getStockTranslation(data.stock_state!);

const favLabel = lang === "en" ? "Add to favorites" : "إضافة إلى المفضلة";
const cardTitle = lang === "en" ? "Click to view product details" : "انقر لعرض تفاصيل المنتج";
---

<div class="group w-full max-w-sm mx-auto h-full">
	<div
		class="glass shadow-soft hover:shadow-vibrant rounded-2xl overflow-hidden transition-all duration-500 hover:transform hover:scale-[1.02] hover:-translate-y-1 bg-white/80 dark:bg-surface/80 backdrop-blur-xl border border-white/20 dark:border-white/10 h-full flex flex-col cursor-pointer product-card-clickable"
		data-product-id={data.id}
		title={cardTitle}
	>
		<div class="relative overflow-hidden rounded-t-2xl">
			<button
				type="button"
				class="favorite-btn absolute top-3 right-3 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white/70 dark:bg-black/40 backdrop-blur-md shadow-soft hover:scale-110 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary/50"
				data-fav-id={data.id}
				aria-pressed="false"
				aria-label={favLabel}
				title={favLabel}
			>
				<span class="fav-icon icon-[mdi--heart-outline] text-2xl text-red-500"></span>
			</button>
			<img
				alt={data.name}
				class="object-cover w-full h-48 sm:h-56 md:h-64 transition-all duration-500 group-hover:scale-110 group-hover:brightness-110"
				loading="lazy"
				src={data.image as string}
			/>
			<div
				class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
			>
			</div>
		</div>

		<div class="p-3 md:p-4 sm:p-5 flex-1 flex flex-col">
			<div class="mb-4">
				<h3
					class="text-lg sm:text-xl font-bold text-text dark:text-white line-clamp-2 group-hover:text-primary dark:group-hover:text-primary transition-colors duration-300 text-center"
				>
					{data.name}
				</h3>
			</div>

			<div class="space-y-3 mt-auto">
				<div class="flex items-center justify-between">
					<span
						class="text-xs sm:text-sm font-medium text-text-muted dark:text-text-secondary uppercase tracking-wide min-w-0 flex-shrink-0"
						>{brandLabel}</span
					>
					<span
						class="text-sm sm:text-base font-semibold text-primary dark:text-accent bg-primary/10 dark:bg-accent/10 px-2 py-1 rounded-full truncate"
					>
						{data.brand.name}
					</span>
				</div>

				<div class="flex items-center justify-between">
					<span
						class="text-xs sm:text-sm font-medium text-text-muted dark:text-text-secondary uppercase tracking-wide min-w-0 flex-shrink-0"
						>{stockLabel}</span
					>
					<span
						class={cn(
							"text-xs sm:text-sm font-bold px-2 py-1 rounded-full uppercase tracking-wide truncate",
							inStock
								? "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400"
								: outOfStock
									? "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400"
									: "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400"
						)}
					>
						{stockTranslation}
					</span>
				</div>

				<div class="flex items-center justify-between">
					<span
						class="text-xs sm:text-sm font-medium text-text-muted dark:text-text-secondary uppercase tracking-wide min-w-0 flex-shrink-0"
						>{categoryLabel}</span
					>
					<span
						class="text-sm sm:text-base font-semibold text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800/50 px-2 py-1 rounded-full truncate border border-gray-200 dark:border-gray-700"
					>
						{data.category.name}
					</span>
				</div>

				{
					data.code_name && (
						<div class="flex items-center justify-between">
							<span class="text-xs sm:text-sm font-medium text-text-muted dark:text-text-secondary uppercase tracking-wide min-w-0 flex-shrink-0">
								{codeNameLabel}
							</span>
							<span class="text-sm sm:text-base font-semibold text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800/50 px-2 py-1 rounded-full truncate border border-gray-200 dark:border-gray-700">
								{data.code_name}
							</span>
						</div>
					)
				}
			</div>
		</div>
	</div>
</div>
