---
const { title, image, link, items_count = 1, alt } = Astro.props;
---

<div class="swiper-slide">
	<div class="flex flex-col gap-3 text-center">
		<a href={link}>
			<img src={image} alt={alt} class="rounded-md w-full h-72 object-cover" /></a
		>
		<a href={link} class="text-2xl font-bold text-center">{title}</a>
		<p class="text-lg text-center">{items_count} عنصر</p>
	</div>
</div>
