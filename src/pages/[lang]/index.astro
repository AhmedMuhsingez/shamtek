---
import type { Product, ProductResponse, ProductsApiResponse } from "../../../types/types";
import CategoriesSection from "../../components/sections/CategoriesSection.astro";
import FeaturedProducts from "../../components/sections/FeaturedProducts.astro";
import HeroSection from "../../components/sections/HeroSection.astro";
import Layout from "../../layouts/Layout.astro";
import GlobalProductDetailsModal from "../../components/GlobalProductDetailsModal";
import { getTranslations, useTranslatedPath } from "../../utils/i18n";
import { cn } from "../../utils/utils";

const { lang } = Astro.params;
const t = await getTranslations(lang as keyof typeof import("../../utils/i18n").languages);
const translatePath = useTranslatedPath(
	lang as keyof typeof import("../../utils/i18n").languages
);
const isRTL = lang as "ar";

const getFeaturedProducts = await fetch(`${import.meta.env.BASE_API}/items?featured=true`);
const featuredProducts: ProductResponse = await getFeaturedProducts.json();
const hasFeaturedProducts = featuredProducts.data.length > 0;
---

<Layout>
	<div class="animate-slideInRight">
		<HeroSection />
	</div>

	<section class="py-16 animate-fadeInUp">
		<div class="text-center mb-12">
			<h2 class="text-3xl md:text-4xl font-bold text-text mb-4">{t.home.whyChooseUs}</h2>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<div
				class="text-center glass p-8 rounded-2xl shadow-vibrant hover:shadow-vibrant-lg transform hover:scale-105 transition-all duration-300 animate-slideInRight"
			>
				<div class="text-5xl mb-4 animate-pulse-custom">⭐</div>
				<h3 class="text-xl font-semibold text-text mb-3">{t.home.quality}</h3>
				<p class="text-text-secondary">
					{
						lang === "ar"
							? "نقدم منتجات عالية الجودة من أفضل العلامات التجارية العالمية"
							: lang === "en"
								? "We offer high-quality products from the best global brands"
								: "En iyi küresel markalardan yüksek kaliteli ürünler sunuyoruz"
					}
				</p>
			</div>
			<div
				class="text-center glass p-8 rounded-2xl shadow-vibrant hover:shadow-vibrant-lg transform hover:scale-105 transition-all duration-300 animate-fadeInUp"
				style="animation-delay: 0.2s;"
			>
				<div class="text-5xl mb-4 animate-pulse-custom" style="animation-delay: 0.5s;">
					🚀
				</div>
				<h3 class="text-xl font-semibold text-text mb-3">{t.home.service}</h3>
				<p class="text-text-secondary">
					{
						lang === "ar"
							? "خدمة عملاء متميزة ودعم فني على مدار الساعة"
							: lang === "en"
								? "Exceptional customer service and 24/7 technical support"
								: "Olağanüstü müşteri hizmeti ve 7/24 teknik destek"
					}
				</p>
			</div>
			<div
				class="text-center glass p-8 rounded-2xl shadow-vibrant hover:shadow-vibrant-lg transform hover:scale-105 transition-all duration-300 animate-slideInLeft"
				style="animation-delay: 0.4s;"
			>
				<div class="text-5xl mb-4 animate-pulse-custom" style="animation-delay: 1s;">
					💰
				</div>
				<h3 class="text-xl font-semibold text-text mb-3">{t.home.prices}</h3>
				<p class="text-text-secondary">
					{
						lang === "ar"
							? "أسعار تنافسية وعروض حصرية لعملائنا الكرام"
							: lang === "en"
								? "Competitive prices and exclusive offers for our valued customers"
								: "Değerli müşterilerimiz için rekabetçi fiyatlar ve özel teklifler"
					}
				</p>
			</div>
		</div>
	</section>

	<!-- Brands Section -->
	<div class="animate-slideInLeft">
		<CategoriesSection currentLang={lang} />
	</div>

	<!-- Featured Products Section -->
	{
		hasFeaturedProducts && (
			<div class="animate-fadeInUp">
				<FeaturedProducts data={featuredProducts.data} />
			</div>
		)
	}

	<!-- CTA Section -->
	<section class="py-16 text-center">
		<div class="glass p-8 md:p-12 rounded-3xl shadow-vibrant-lg animate-fadeInUp">
			<h2 class="text-3xl md:text-4xl font-bold text-text mb-6">
				{
					lang === "ar"
						? "اكتشف مجموعتنا الكاملة"
						: lang === "en"
							? "Discover Our Complete Collection"
							: "Tam Koleksiyonumuzu Keşfedin"
				}
			</h2>
			<p class="text-text-secondary text-lg mb-8 max-w-2xl mx-auto">
				{
					lang === "ar"
						? "تصفح آلاف المنتجات من أحدث التقنيات والإلكترونيات"
						: lang === "en"
							? "Browse thousands of products from the latest technologies and electronics"
							: "En son teknolojiler ve elektroniklerden binlerce ürüne göz atın"
				}
			</p>
			<a
				href={translatePath("/all-products")}
				aria-label="See all products"
				class="group inline-flex items-center gap-3 bg-gradient-secondary text-white px-10 py-5 rounded-2xl text-xl font-semibold shadow-vibrant-md hover:shadow-vibrant-lg transform hover:scale-105 transition-all duration-300 animate-pulse-custom"
			>
				<span>✨</span>
				<span>{t.nav.allProducts}</span>
				<span
					class={cn(
						"icon-[material-symbols--arrow-back-rounded] group-hover:-translate-x-3 transition-all duration-300",
						!isRTL && "rotate-180 group-hover:translate-x-3"
					)}></span>
			</a>
		</div>
	</section>

	<GlobalProductDetailsModal client:load />
</Layout>
