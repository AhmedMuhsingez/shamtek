---
import GlobalProductDetailsModal from "../../../components/GlobalProductDetailsModal";
import ProductsView from "../../../components/ProductsView.astro";
import PageHeader from "../../../components/sections/PageHeader.astro";
import Layout from "../../../layouts/Layout.astro";
import { getTranslations } from "../../../utils/i18n";
import { languages } from "../../../utils/i18n";
import {
	categories,
	getCategoryBySlug,
	products,
	localizeProducts,
	localizeCategoryName,
	localizeCategoryDescription,
	type Lang,
} from "../../../data/dummy-data";

export function getStaticPaths() {
	return Object.keys(languages).flatMap((lang) =>
		categories.map((category) => ({ params: { lang, category: category.slug } }))
	);
}

const { category } = Astro.params;
const { lang } = Astro.params as { lang: string };
const t = await getTranslations(lang as keyof typeof import("../../../utils/i18n").languages);

const categoryData = getCategoryBySlug(category);

if (!categoryData) {
	return Astro.redirect("/404");
}

const categoryName = localizeCategoryName(categoryData.slug, categoryData.name, lang as Lang);
const categoryDescription = localizeCategoryDescription(
	categoryData.slug,
	categoryData.description,
	lang as Lang
);
const categoryProducts = localizeProducts(
	products.filter((p) => p.categoryId === categoryData.id),
	lang as Lang
);
---

<Layout>
	<PageHeader name={categoryName} description={categoryDescription} isCategory />

	<ProductsView
		products={categoryProducts}
		noItemsTitle={t.brands.noItemsTitle}
		noItemsDescription={t.brands.noItemsDescription}
	/>

	<GlobalProductDetailsModal client:load />
</Layout>
