---
import type { Product, ProductResponse } from "../../../types/types";
import ProductCard from "../../components/ProductCard.astro";
import PageHeader from "../../components/sections/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";
import GlobalProductDetailsModal from "../../components/GlobalProductDetailsModal";
import Pagination from "../../components/sections/Pagination.astro";

const page = Astro.url.searchParams.get("page") ?? 1;

const products = await fetch(`${import.meta.env.BASE_API}/items?page=${page}`);
const data: ProductResponse = await products.json();
---

<Layout>
	<PageHeader />
	<div
		class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 flex-col gap-4 justify-between py-10"
	>
		{
			data.data.map((product: Product) => {
				return <ProductCard product={product} />;
			})
		}
	</div>

	<Pagination totalItems={data.meta.totalPages} />

	<GlobalProductDetailsModal client:load />
</Layout>
