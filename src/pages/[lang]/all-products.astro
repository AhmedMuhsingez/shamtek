---
import ProductsView from "../../components/ProductsView.astro";
import PageHeader from "../../components/sections/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";
import GlobalProductDetailsModal from "../../components/GlobalProductDetailsModal";
import { getStaticPathsForI18n } from "../../utils/i18n";
import { products } from "../../data/dummy-data";

export function getStaticPaths() {
	return getStaticPathsForI18n();
}
---

<Layout>
	<PageHeader />

	<ProductsView products={products} />

	<GlobalProductDetailsModal client:load />
</Layout>
