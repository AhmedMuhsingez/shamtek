---
import type { Product } from "../../../../types/types";
import Layout from "../../../layouts/Layout.astro";
import { useTranslatedPath, languages } from "../../../utils/i18n";
import { cn } from "../../../utils/utils";
import MarkdownViewer from "../../../components/MarkdownViewer";
import { isWhatsAppAvailable } from "../../../utils/whatsapp";
import { products, getProductById } from "../../../data/dummy-data";

export function getStaticPaths() {
	return Object.keys(languages).flatMap((lang) =>
		products.map((p) => ({ params: { lang, product: p.id } }))
	);
}

const { product: productId } = Astro.params;

const { lang } = Astro.params as { lang: string };
const translatePath = useTranslatedPath(
	lang as keyof typeof import("../../../utils/i18n").languages
);
const isRTL = lang === "ar";

const product: Product | null = getProductById(productId);

if (!product) {
	return Astro.redirect("/404");
}

const stockState = product?.stock_state?.toLowerCase();
const isInStock = stockState === "in_stock";
const isOutOfStock = stockState === "out_of_stock";

const getStockLabel = () => {
	if (isInStock) return lang === "ar" ? "متوفر" : lang === "en" ? "In Stock" : "Stokta";
	if (isOutOfStock)
		return lang === "ar" ? "غير متوفر" : lang === "en" ? "Out of Stock" : "Stokta Yok";
	return lang === "ar" ? "قادم قريباً" : lang === "en" ? "Coming Soon" : "Yakında";
};

const getStockColor = () => {
	if (isInStock) return "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400";
	if (isOutOfStock) return "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400";
	return "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400";
};

const productImage = Array.isArray(product?.image) ? product.image[0] : product?.image;

const whatsappAvailable = isWhatsAppAvailable();

const getWhatsAppButtonText = () => {
	switch (lang) {
		case "en":
			return "Inquire via WhatsApp";
		case "tr":
			return "WhatsApp ile Sorgula";
		default:
			return "استفسار عبر واتساب";
	}
};

// SEO and Open Graph data
const pageTitle = `${product?.name} | ${lang === "ar" ? "شامتك" : lang === "en" ? "Shamtek" : "Shamtek"}`;
const pageDescription =
	product?.description ||
	(lang === "ar"
		? "منتج عالي الجودة من شامتك"
		: lang === "en"
			? "High quality product from Shamtek"
			: "Shamtek'ten yüksek kaliteli ürün");
const canonicalUrl = `${Astro.site}${lang}/product/${productId}`;
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonicalURL={canonicalUrl}
	openGraph={{
		title: pageTitle,
		description: pageDescription,
		image: productImage as string,
		url: canonicalUrl,
		type: "product",
	}}
>
	<div class="">
		<!-- Breadcrumb Navigation -->
		<nav class="container mx-auto px-4 py-6">
			<div
				class="flex items-center space-x-2 text-sm text-gray-600 dark:text-gray-400"
				dir={isRTL ? "rtl" : "ltr"}
			>
				<a
					href={translatePath("/")}
					class="hover:text-primary text-white transition-colors"
				>
					{lang === "ar" ? "الرئيسية" : lang === "en" ? "Home" : "Ana Sayfa"}
				</a>
				<span class="text-gray-400">/</span>
				<a
					href={translatePath("/all-products")}
					class="hover:text-primary transition-colors text-white"
				>
					{
						lang === "ar"
							? "جميع المنتجات"
							: lang === "en"
								? "All Products"
								: "Tüm Ürünler"
					}
				</a>
				<span class="text-gray-400">/</span>
				<span class="text-primary font-medium">{product.name}</span>
			</div>
		</nav>

		<!-- Product Details Section -->
		<div class="container mx-auto pb-16">
			<div
				class="bg-white/95 dark:bg-gray-900/95 backdrop-blur-xl border border-white/20 dark:border-gray-700/50 shadow-2xl rounded-3xl overflow-hidden"
			>
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
					<!-- Product Image -->
					<div class="relative overflow-hidden">
						<img
							src={productImage as string}
							alt={product.name}
							class="w-full h-64 sm:h-80 lg:h-full object-cover transition-transform duration-500 hover:scale-105"
						/>
						<div
							class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent"
						>
						</div>
					</div>

					<!-- Product Information -->
					<div class="p-6 sm:p-8 lg:p-12 content-center" dir={isRTL ? "rtl" : "ltr"}>
						<h1
							class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight"
						>
							{product.name}
						</h1>

						{
							product.description && (
								<div class="mb-8">
									<MarkdownViewer content={product.description} />
								</div>
							)
						}

						<!-- Product Details Grid -->
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
							<!-- Brand -->
							<div
								class="bg-gray-50/80 dark:bg-gray-800/50 rounded-xl p-4 border border-gray-200 dark:border-gray-700/50"
							>
								<div class="flex items-center justify-between">
									<span
										class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide"
									>
										{
											lang === "ar"
												? "العلامة التجارية"
												: lang === "en"
													? "Brand"
													: "Marka"
										}
									</span>
									<span
										class="text-base font-semibold text-primary dark:text-accent bg-primary/10 dark:bg-accent/10 px-3 py-1 rounded-full"
									>
										{product.brand?.name}
									</span>
								</div>
							</div>

							<!-- Category -->
							<div
								class="bg-gray-50/80 dark:bg-gray-800/50 rounded-xl p-4 border border-gray-200 dark:border-gray-700/50"
							>
								<div class="flex items-center justify-between">
									<span
										class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide"
									>
										{
											lang === "ar"
												? "القسم"
												: lang === "en"
													? "Category"
													: "Kategori"
										}
									</span>
									<span
										class="text-base font-semibold text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700/50 px-3 py-1 rounded-full border border-gray-200 dark:border-gray-600"
									>
										{product.category?.name || "N/A"}
									</span>
								</div>
							</div>

							<!-- Stock Status -->
							<div
								class="bg-gray-50/80 dark:bg-gray-800/50 rounded-xl p-4 border border-gray-200 dark:border-gray-700/50"
							>
								<div class="flex items-center justify-between">
									<span
										class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide"
									>
										{
											lang === "ar"
												? "الحالة"
												: lang === "en"
													? "Status"
													: "Durum"
										}
									</span>
									<span
										class={cn(
											"text-sm font-bold px-3 py-1 rounded-full uppercase tracking-wide",
											getStockColor()
										)}
									>
										{getStockLabel()}
									</span>
								</div>
							</div>

							<!-- Code Name -->
							{
								product.code_name && (
									<div class="bg-gray-50/80 dark:bg-gray-800/50 rounded-xl p-4 border border-gray-200 dark:border-gray-700/50">
										<div class="flex items-center justify-between">
											<span class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">
												{lang === "ar"
													? "رقم المنتج"
													: lang === "en"
														? "Product Code"
														: "Ürün Kodu"}
											</span>
											<span class="text-base font-semibold text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700/50 px-3 py-1 rounded-full border border-gray-200 dark:border-gray-600 font-mono">
												{product.code_name}
											</span>
										</div>
									</div>
								)
							}
						</div>

						<!-- Action Buttons -->
						<div class="flex flex-col sm:flex-row gap-4">
							{
								whatsappAvailable && (
									<button
										id="whatsapp-btn"
										class="cursor-pointer flex-1 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white font-semibold py-4 px-6 rounded-xl shadow-lg hover:shadow-xl transform hover:scale-[1.02] transition-all duration-300 flex items-center justify-center gap-3 group"
									>
										<span class="icon-[ic--twotone-whatsapp] text-xl group-hover:scale-110 transition-transform duration-300" />
										<span class="text-lg">{getWhatsAppButtonText()}</span>
										<span class="icon-[material-symbols--arrow-outward] text-xl group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform duration-300" />
									</button>
								)
							}

							<button
								id="copy-btn"
								class="cursor-pointer bg-gradient-to-r from-gray-500 to-gray-600 hover:from-gray-600 hover:to-gray-700 text-white font-semibold py-4 px-6 rounded-xl shadow-lg hover:shadow-xl transform hover:scale-[1.02] transition-all duration-300 flex items-center justify-center gap-3 group"
							>
								<span
									class="icon-[solar--copy-line-duotone] group-hover:scale-125 transition-transform duration-300"
								></span>
								<span class="text-lg">
									{
										lang === "ar"
											? "نسخ الرابط"
											: lang === "en"
												? "Copy Link"
												: "Bağlantıyı Kopyala"
									}
								</span>
							</button>
						</div>

						<!-- Additional Info -->
						<div class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-700">
							<div
								class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 text-sm text-gray-500 dark:text-gray-400"
							>
								<span>
									{
										lang === "ar"
											? "تاريخ الإضافة"
											: lang === "en"
												? "Added on"
												: "Eklenme Tarihi"
									}:
									{
										product.createdAt
											? new Date(product.createdAt).toLocaleDateString()
											: "N/A"
									}
								</span>
								<!-- <span>
									{
										lang === "ar"
											? "أضيف بواسطة"
											: lang === "en"
												? "Added by"
												: "Ekleyen"
									}: {product.addedBy?.name || "N/A"}
								</span> -->
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<script>
		// WhatsApp functionality
		document.getElementById("whatsapp-btn")?.addEventListener("click", () => {
			const product = JSON.parse(
				document.getElementById("product-data")?.textContent || "{}"
			);
			const lang = document.documentElement.lang || "ar";

			try {
				// This would need to be implemented based on your WhatsApp utility
				const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(`Check out this product: ${product.name} - ${window.location.href}`)}`;
				window.open(whatsappUrl, "_blank", "noopener,noreferrer");
			} catch (error) {
				console.error("Error opening WhatsApp:", error);
			}
		});

		// Copy to clipboard functionality
		document.getElementById("copy-btn")?.addEventListener("click", async () => {
			try {
				if (navigator.clipboard) {
					await navigator.clipboard.writeText(window.location.href);
				} else {
					// Fallback for older browsers
					const textArea = document.createElement("textarea");
					textArea.value = window.location.href;
					textArea.style.position = "fixed";
					textArea.style.opacity = "0";
					document.body.appendChild(textArea);
					textArea.select();
					document.execCommand("copy");
					document.body.removeChild(textArea);
				}

				// Show success feedback
				const btn = document.getElementById("copy-btn");
				const originalText = btn?.innerHTML;
				if (btn) {
					btn.innerHTML =
						'<span class="icon-[material-symbols--check] text-xl"></span><span>تم النسخ!</span>';
					btn.classList.add("bg-green-500", "hover:bg-green-600");
					btn.classList.remove(
						"bg-gradient-to-r",
						"from-gray-500",
						"to-gray-600",
						"hover:from-gray-600",
						"hover:to-gray-700"
					);

					setTimeout(() => {
						if (originalText) btn.innerHTML = originalText;
						btn.classList.remove("bg-green-500", "hover:bg-green-600");
						btn.classList.add(
							"bg-gradient-to-r",
							"from-gray-500",
							"to-gray-600",
							"hover:from-gray-600",
							"hover:to-gray-700"
						);
					}, 2000);
				}
			} catch (error) {
				console.error("Failed to copy to clipboard:", error);
			}
		});
	</script>

	<!-- Hidden product data for JavaScript -->
	<script type="application/json" id="product-data" set:html={JSON.stringify(product)} />

	<script>
		// Persist this product view to the localStorage "recently viewed" list.
		import { addRecentlyViewed } from "../../../utils/storage";

		function recordView() {
			try {
				const raw = document.getElementById("product-data")?.textContent;
				if (!raw) return;
				const { id } = JSON.parse(raw);
				if (id) addRecentlyViewed(String(id));
			} catch (error) {
				console.error("Failed to record recently viewed product:", error);
			}
		}

		document.addEventListener("astro:page-load", recordView);
		if (document.readyState !== "loading") recordView();
		else document.addEventListener("DOMContentLoaded", recordView);
	</script>
</Layout>
