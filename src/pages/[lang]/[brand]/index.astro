---
import ProductCard from "../../../components/ProductCard.astro";
import Layout from "../../../layouts/Layout.astro";
import { getStaticPathsForI18n, getTranslations } from "../../../utils/i18n";
import type { Product, Brand } from "../../../../types/types";

export async function getStaticPaths() {
	// Get all brands to generate static paths
	try {
		const brandsResponse = await fetch(`${import.meta.env.BASE_API}/brands`);
		const brands: Brand[] = await brandsResponse.json();

		const paths: Array<{
			params: { lang: string; brand: string };
			props: { brandData: Brand };
		}> = [];
		const languages = ["ar", "en", "tr"];

		for (const lang of languages) {
			for (const brand of brands) {
				const brandSlug = brand.name
					.toLowerCase()
					.replace(/\s+/g, "-")
					.replace(/[^a-z0-9-]/g, "");
				paths.push({
					params: { lang, brand: brandSlug },
					props: { brandData: brand },
				});
			}
		}

		return paths;
	} catch (error) {
		console.error("Error fetching brands for static paths:", error);
		return getStaticPathsForI18n();
	}
}

const { lang, brand: brandSlug } = Astro.params as { lang: string; brand: string };
const { brandData } = Astro.props as { brandData?: Brand };
const t = await getTranslations(lang as keyof typeof import("../../../utils/i18n").languages);

// Fetch brand-specific products
let brandProducts: Product[] = [];
let brandName = "";

try {
	if (brandData) {
		// Use the brand data passed from getStaticPaths
		brandName = brandData.name;
		// Fetch products for this specific brand
		const productsResponse = await fetch(`${import.meta.env.BASE_API}/items`);
		if (productsResponse.ok) {
			brandProducts = await productsResponse.json();
		}
	}
} catch (error) {
	console.error("Error fetching brand products:", error);
	// Fallback to brand name from slug
	brandName = brandSlug
		? brandSlug.replace(/-/g, " ").replace(/\b\w/g, (l: string) => l.toUpperCase())
		: "Brand";
}
---

<Layout>
	<!-- Brand Header -->
	<div class="text-center animate-fadeInUp w-full items-center flex justify-center mb-6">
		<h1
			class="text-4xl md:text-5xl font-bold text-text mb-4 bg-gradient-primary bg-clip-text w-fit px-4 py-3 rounded-br-xl rounded-tl-xl"
		>
			{brandName}
		</h1>
	</div>

	<!-- Products Section -->
	<div class="container mx-auto px-4 pb-16">
		{
			brandProducts.length > 0 ? (
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 animate-slideInUp">
					{brandProducts.map((product, index) => {
						const productImages = Array.isArray(product.image)
							? product.image
							: [product.image];
						return (
							<div
								class="animate-fadeInUp transition-all duration-300 hover:transform hover:scale-105"
								style={`animation-delay: ${index * 0.1}s;`}
							>
								<ProductCard
									title={product.name}
									image={productImages}
									link={`/product/${product.id}`}
								/>
							</div>
						);
					})}
				</div>
			) : (
				// <!-- No Products Message -->
				<div class="text-center py-20 animate-fadeInUp">
					<div class="glass p-12 rounded-3xl shadow-vibrant-lg max-w-md mx-auto">
						<div class="text-6xl mb-6 opacity-50">📦</div>
						<h2 class="text-2xl font-semibold text-text mb-4">
							{t.brands.noItemsTitle}
						</h2>
						<p class="text-text-secondary">{t.brands.noItemsDescription}</p>
					</div>
				</div>
			)
		}
	</div>
</Layout>
