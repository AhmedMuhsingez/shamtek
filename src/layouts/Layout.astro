---
import Navbar from "../components/Navbar.astro";
import BaseHead from "./BaseHead.astro";
import "../styles/global.css";
import SizeIndicator from "../components/custom/SizeIndicator.astro";
import Footer from "../components/sections/Footer.astro";
import { getLangFromUrl, getDirection } from "../utils/i18n";
import ClientRouter from "astro/components/ClientRouter.astro";
import LoadingIndicator from "astro-loading-indicator/component";
// import GlobalProductModal from "../components/GlobalProductModal";

const lang = getLangFromUrl(Astro.url);
const direction = getDirection(lang);
---

<!doctype html>
<html lang={lang} dir={direction} class="overflow-y-scroll smooth-scroll">
	<head>
		<BaseHead currentLang={lang} />
		<script>
			// Prevent flash of unstyled content (FOUC) for theme
			(function () {
				const getInitialTheme = () => {
					const stored = localStorage.getItem("theme");
					if (stored) return stored;
					return window.matchMedia("(prefers-color-scheme: dark)").matches
						? "dark"
						: "light";
				};
				document.documentElement.classList.add(getInitialTheme());
			})();
		</script>
		<LoadingIndicator color="#667eea" />
	</head>

	<body class="antialiased bg-background font-cairo text-text" id="website">
		<Navbar currentLang={lang} />
		<SizeIndicator />
		<div class="max-w-7xl mt-10 mx-4 md:mx-auto" id="website-body">
			<slot />
		</div>
		<Footer currentLang={lang} />
		<!-- <GlobalProductModal client:load /> -->
		<ClientRouter />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		scrollbar-gutter: stable;
		scroll-behavior: smooth;
		transition:
			background-color 0.5s ease-in-out,
			color 0.3s ease-in-out;
	}

	/* Enhanced scrollbar styling */
	::-webkit-scrollbar {
		width: 8px;
	}

	::-webkit-scrollbar-track {
		background: var(--color-background-secondary);
	}

	::-webkit-scrollbar-thumb {
		background: var(--color-primary);
		border-radius: 4px;
		transition: background-color 0.3s ease;
	}

	::-webkit-scrollbar-thumb:hover {
		background: var(--color-primary-dark);
	}

	/* Selection styling */
	::selection {
		background: var(--color-primary-light);
		color: white;
	}

	/* Focus visible for accessibility */
	:focus-visible {
		outline: 2px solid var(--color-primary);
		outline-offset: 2px;
		border-radius: 4px;
	}
</style>
