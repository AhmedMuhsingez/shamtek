---
import { ClientRouter } from "astro:transitions";
import LoadingIndicator from "astro-loading-indicator/component";
import { getTranslations } from "../utils/i18n";
import { companyData } from "../data/company-details";

interface Props {
	currentLang?: string;
}

const { currentLang = "ar" } = Astro.props;
const t = await getTranslations(currentLang as keyof typeof import("../utils/i18n").languages);
---

<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta charset="UTF-8" />

<!-- SEO -->

<meta name="description" content={t.common.description} />
<meta property="og:title" content="ShamTek" />
<meta
	property="og:description"
	content="Discover high-quality products at unbeatable prices. Your one-stop destination for advanced technology."
/>
<meta property="og:image" content={companyData.logo} />
<meta property="og:url" content="https://sham-tek.com" />

<link rel="icon" type="image/png" href="/logo.jpeg" />

<title>{t.common.brandName}</title>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap"
	rel="stylesheet"
/>

<ClientRouter />
<LoadingIndicator color="#474e18" />

<script type="text/javascript">
	(function (c, l, a, r, i, t, y) {
		c[a] =
			c[a] ||
			function () {
				(c[a].q = c[a].q || []).push(arguments);
			};
		t = l.createElement(r);
		t.async = 1;
		t.src = "https://www.clarity.ms/tag/" + i;
		y = l.getElementsByTagName(r)[0];
		y.parentNode.insertBefore(t, y);
	})(window, document, "clarity", "script", "t52jtv130t");
</script>
